#include <stdio.h>
#define TAMAÑO1 5
#define TAMAÑO2 10
#define TAMAÑOFINAL 15
int main() 
{
    int vector1 [TAMAÑO1];
    int vector2 [TAMAÑO2];
    int vector3 [TAMAÑOFINAL];
    int indice=0;
    int numElementos1=0;
    int numElementos2=0;
    int numElementos3=0;
    printf("\nEscribe un numero entre 1 y 5 para definir el tamaño del vector 1\n");
    scanf("%d",&numElementos1);
    if ((numElementos1>=1) && (numElementos1<=5))
    {
        for (indice = 0 ; indice <= numElementos1-1 ; indice++)
        {
            printf("\nDigite un valor entero para el elemento %d del vector 1\n", indice);
            scanf("%d", &vector1[indice]);
        }
    }
        else printf("\nEl numero dado no es válido");
        
    printf("\nEscribe un numero entre 1 y 10 para definir el tamaño del vector 2\n");
    scanf("%d",&numElementos2);
    if((numElementos2>=1) && (numElementos2<=10))
    {
        for (indice = 0 ; indice <= numElementos2-1 ; indice++)
        {
            printf("\nDigite un valor entero para el elemento %d del vector 2\n", indice);
            scanf("%d", &vector2[indice]);
        }
    }
        else printf("\nEl numero dado no es válido");
    
    
    printf("\nEl vector final se compone de los siguientes elementos:\n");
    
    for (indice = 0 ; indice <= numElementos3-1; indice++)
    {
        printf("%d", vector3[indice]);
    }
    
    return 0;
}
